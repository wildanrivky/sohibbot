# ============================================================
# {{BOT_NAME}} — Configuration
# Copy ke .env (wizard setup.py yang isi otomatis)
# Jangan commit .env ke Git!
# ============================================================

# --- Identitas ---
BOT_NAME=
BOT_SLUG=
USER_NAME=
USER_EMAIL=

# --- Claude CLI ---
# Jalankan "which claude" di terminal untuk tahu pathnya
CLAUDE_CLI_PATH=
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6

# --- Telegram ---
# Token dari @BotFather
TELEGRAM_BOT_TOKEN=
# User ID numerik — dapat dari @userinfobot
TELEGRAM_OWNER_ID=

# --- Service (auto-restart) ---
SERVICE_LABEL=
BOT_LOG=/tmp/{{BOT_SLUG}}.log
BOT_ERR_LOG=/tmp/{{BOT_SLUG}}.error.log

# --- Paths ---
MEMORY_DIR=./memory
DATA_DIR=./data

# --- App ---
LOG_LEVEL=INFO
